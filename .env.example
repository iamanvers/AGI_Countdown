# =============================================================================
# AGI Countdown — environment variables (all optional; the app runs at $0)
# =============================================================================

# --- Web app -----------------------------------------------------------------
# Canonical site origin, used for metadata / Open Graph base URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- "Trigger refresh" button (server route: /api/refresh) -------------------
# When set, the website can dispatch the on-demand GitHub Actions refresh.
# Use a fine-grained PAT with "Actions: read and write" on this repo only.
# Leave blank to disable the button gracefully (it shows "not configured").
GITHUB_DISPATCH_TOKEN=
GITHUB_REPOSITORY=owner/repo
GITHUB_REFRESH_WORKFLOW=refresh-manual.yml
GITHUB_REF_NAME=main

# --- Pipeline: optional free source API keys (used only in GitHub Actions) ---
# The web app must never depend on any secret.
EIA_API_KEY=
BLS_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# --- Optional LLM enrichment (disabled by default) ---------------------------
ENABLE_LLM_ENRICHMENT=false
ANTHROPIC_API_KEY=
