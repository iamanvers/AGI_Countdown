{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "paths": {
      "@agi-countdown/config": ["../../packages/config/src/index.ts"],
      "@agi-countdown/engine": ["../../packages/engine/src/index.ts"],
      "@agi-countdown/sources": ["../../packages/sources/src/index.ts"]
    },
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../../packages/config" },
    { "path": "../../packages/engine" },
    { "path": "../../packages/sources" }
  ]
}
